<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Student Portal</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{
            background:#f1f5f9;
            overflow-x:hidden;
        }

        .sidebar{
            width:250px;
            height:100vh;
            position:fixed;
            left:0;
            top:0;
            background:#0f172a;
            color:white;
            padding:20px;
            display:flex;
            flex-direction:column;
        }

        .sidebar h3{
            margin-bottom:30px;
            text-align:center;
        }

        .sidebar ul{
            list-style:none;
            padding-left:0;
            flex:1;
        }

        .sidebar ul li{
            margin-bottom:12px;
        }

        .sidebar ul li a{
            color:white;
            text-decoration:none;
            display:block;
            padding:12px 15px;
            border-radius:10px;
            transition:0.3s;
        }

        .sidebar ul li a:hover{
            background:#2563eb;
        }

        .logout-btn{
            margin-top:20px;
        }

        .content{
            margin-left:250px;
            padding:30px;
        }

        .card{
            border:none;
            border-radius:15px;
            box-shadow:0 5px 15px rgba(0,0,0,.08);
        }

        table{
            background:white;
        }

        .btn-success{
            border-radius:10px;
        }

        .btn-primary{
            border-radius:10px;
        }

        .page-title{
            margin-bottom:25px;
            font-weight:bold;
        }

    </style>

</head>

<body>

    <!-- Sidebar -->

    <div class="sidebar">

        <div>

            <h3>🎓 Student Portal</h3>

            <ul>

                <li>
                    <a href="/Dashboard/Index">
                        <i class="fas fa-home"></i>
                        Dashboard
                    </a>
                </li>

                <li>
                    <a href="/Student/Index">
                        <i class="fas fa-user-graduate"></i>
                        Students
                    </a>
                </li>

                <li>
                    <a href="/Attendance/Index">
                        <i class="fas fa-calendar-check"></i>
                        Attendance
                    </a>
                </li>

                <li>
                    <a href="/Attendance/History">
                        <i class="fas fa-history"></i>
                        Attendance History
                    </a>
                </li>

                <li>
                    <a href="/Results/Index">
                        <i class="fas fa-chart-line"></i>
                        Results
                    </a>
                </li>

                <li>
                    <a href="/Results/History">
                        <i class="fas fa-file-alt"></i>
                        Result History
                    </a>
                </li>

                <li>
                    <a href="/Fees/Index">
                        <i class="fas fa-money-bill"></i>
                        Fees
                    </a>
                </li>

                <li>
                    <a href="/Fees/History">
                        <i class="fas fa-wallet"></i>
                        Fee History
                    </a>
                </li>

                <li>
                    <a href="/Notice/Index">
                        <i class="fas fa-bullhorn"></i>
                        Notices
                    </a>
                </li>

            </ul>

        </div>

        <!-- Logout Button -->

        <div class="logout-btn">

            <a href="/Account/Logout"
               class="btn btn-danger w-100">

                <i class="fas fa-sign-out-alt"></i>
                Logout

            </a>

        </div>

    </div>

    <!-- Main Content -->

    <div class="content">

        @RenderBody()

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>