@model StudentPortal.Models.Student

<h1>Edit Student</h1>

<form method="post">

    <input asp-for="Id" hidden />

    <div class="mb-3">
        <label>Name</label>
        <input asp-for="Name"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Roll No</label>
        <input asp-for="RollNo"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Course</label>
        <input asp-for="Course"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Email</label>
        <input asp-for="Email"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Phone</label>
        <input asp-for="Phone"
               class="form-control" />
    </div>

    <button type="submit"
            class="btn btn-primary">
        Update Student
    </button>

</form>