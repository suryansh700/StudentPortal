@model List<StudentPortal.Models.Student>

@{
    ViewData["Title"] = "Results";

    var totalStudents = Model.Count;
}

<h1 class="mb-4 fw-bold">
    Results Management
</h1>

<div class="row mb-4">

    <div class="col-md-3">

        <div class="card shadow border-0 rounded-4">

            <div class="card-body text-center">

                <h6>Total Students</h6>

                <h2 class="text-primary">
                    @totalStudents
                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-3">

        <div class="card shadow border-0 rounded-4">

            <div class="card-body text-center">

                <h6>Subjects</h6>

                <h2 class="text-success">
                    3
                </h2>

            </div>

        </div>

    </div>

</div>

<div class="card shadow-lg border-0 rounded-4">

    <div class="card-header bg-primary text-white">

        <h3 class="mb-0">
            Enter Student Result
        </h3>

    </div>

    <div class="card-body">

        <input type="text"
               id="searchBox"
               class="form-control mb-4"
               placeholder="Search Student..." />

        <form method="post"
              asp-action="Save">

            <table class="table table-hover table-bordered"
                   id="resultTable">

                <thead class="table-dark">

                    <tr>

                        <th>Photo</th>

                        <th>Name</th>

                        <th>Roll No</th>

                        <th>Java</th>

                        <th>Python</th>

                        <th>DBMS</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach(var student in Model)
                    {
                        <tr>

                            <td>

                                <img src="@student.PhotoPath"
                                     width="70"
                                     height="70"
                                     style="
                                     border-radius:50%;
                                     object-fit:cover;
                                     border:3px solid #0d6efd;" />

                            </td>

                            <td>

                                <strong>
                                    @student.Name
                                </strong>

                            </td>

                            <td>

                                @student.RollNo

                            </td>

                            <td>

                                <input type="number"
                                       name="java"
                                       min="0"
                                       max="100"
                                       class="form-control marks"
                                       required />

                            </td>

                            <td>

                                <input type="number"
                                       name="python"
                                       min="0"
                                       max="100"
                                       class="form-control marks"
                                       required />

                            </td>

                            <td>

                                <input type="number"
                                       name="dbms"
                                       min="0"
                                       max="100"
                                       class="form-control marks"
                                       required />

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

            <button
                type="submit"
                class="btn btn-success btn-lg">

                Save Results

            </button>

            <a href="/Results/History"
               class="btn btn-primary btn-lg">

                View Result History

            </a>

        </form>

    </div>

</div>

<script>

document
.getElementById("searchBox")
.addEventListener("keyup",
function () {

let value =
this.value.toLowerCase();

let rows =
document.querySelectorAll(
"#resultTable tbody tr"
);

rows.forEach(row => {

row.style.display =

row.innerText
.toLowerCase()
.includes(value)

? ""

: "none";

});

});

</script>